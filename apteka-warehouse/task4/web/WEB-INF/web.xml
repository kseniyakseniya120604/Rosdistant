<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                              http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <display-name>Apteka Warehouse</display-name>

    <!-- Стартовая страница приложения -->
    <welcome-file-list>
        <welcome-file>medicines</welcome-file>
    </welcome-file-list>

    <!-- Регистрация сервлета-контроллера (дублирует @WebServlet, приведено
         явно, т.к. задание требует разработки дескриптора развёртывания) -->
    <servlet>
        <servlet-name>MedicineServlet</servlet-name>
        <servlet-class>ru.apteka.servlet.MedicineServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>MedicineServlet</servlet-name>
        <url-pattern>/medicines</url-pattern>
    </servlet-mapping>

    <!-- Кодировка запросов -->
    <filter>
        <filter-name>EncodingFilter</filter-name>
        <filter-class>ru.apteka.servlet.EncodingFilter</filter-class>
        <init-param>
            <param-name>encoding</param-name>
            <param-value>UTF-8</param-value>
        </init-param>
    </filter>

    <filter-mapping>
        <filter-name>EncodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

</web-app>
